---
import { withBase } from '../lib/paths';
interface Props { title: string; href?: string; linkLabel?: string }
const { title, href, linkLabel = 'Смотреть все' } = Astro.props;
---
<div class="section-title">
  <h2>{title}</h2>
  {href && <a href={withBase(href)}>{linkLabel} <span aria-hidden="true">→</span></a>}
</div>
<style>
  .section-title { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; padding-bottom: .8rem; border-bottom: 1px solid var(--border); }
  h2 { margin: 0; font-family: var(--font-display); font-size: clamp(1.9rem, 3vw, 2.45rem); font-weight: 400; color: var(--text-bright); }
  a { color: var(--text-muted); text-decoration: none; font-size: .88rem; white-space: nowrap; }
  a:hover { color: var(--gold); }
</style>
