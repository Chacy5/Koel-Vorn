---
import { withBase } from '../lib/paths';
interface Props { title: string; slug: string; session: number; excerpt: string; cover: string }
const { title, slug, session, excerpt, cover } = Astro.props;
---
<article class="diary-card reveal-card">
  <a class="cover" href={withBase(`/diary/${slug}`)} tabindex="-1" aria-hidden="true">
    <img src={withBase(cover)} alt="" loading="lazy" />
  </a>
  <div class="card-body">
    <p class="eyebrow">Запись · Серия {session}</p>
    <h3><a href={withBase(`/diary/${slug}`)}>{title}</a></h3>
    <p>{excerpt}</p>
    <div class="card-footer"><span>Серия {session}</span><a href={withBase(`/diary/${slug}`)} aria-label={`Читать: ${title}`}>→</a></div>
  </div>
</article>
<style>
  .diary-card { min-width: 0; background: var(--bg-card); border: 1px solid var(--border); transition: transform .25s, border-color .25s, box-shadow .25s; }
  .diary-card:hover { transform: translateY(-4px); border-color: rgba(182,154,99,.58); box-shadow: 0 10px 35px rgba(0,0,0,.28), inset 0 0 30px rgba(182,154,99,.025); }
  .cover { display: block; height: 180px; overflow: hidden; background: #0c0c0b; }
  .cover img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.7) brightness(.78); transition: filter .3s, transform .5s; }
  .diary-card:hover img { filter: saturate(.85) brightness(.9); transform: scale(1.025); }
  .card-body { padding: 1.35rem 1.35rem 1rem; }
  .eyebrow { margin: 0 0 .45rem; color: var(--gold); font-size: .75rem; text-transform: uppercase; letter-spacing: .09em; }
  h3 { margin: 0; font-family: var(--font-display); font-size: 1.45rem; font-weight: 500; }
  h3 a { color: var(--text-bright); text-decoration: none; }
  .card-body > p:not(.eyebrow) { min-height: 4.7em; color: var(--text-muted); line-height: 1.55; }
  .card-footer { display: flex; justify-content: space-between; align-items: center; color: var(--text-muted); font-size: .78rem; }
  .card-footer a { color: var(--gold); text-decoration: none; font-size: 1.3rem; }
</style>
