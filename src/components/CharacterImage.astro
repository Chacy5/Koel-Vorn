---
interface Props { name: string; src?: string; class?: string; loading?: 'eager' | 'lazy' }
const { name, src, class: className, loading = 'lazy' } = Astro.props;
---
<span class:list={['character-image', className, { 'is-fallback': !src }]} data-character-image>
  {src && <img src={src} alt={name} width="640" height="640" loading={loading} decoding="async" />}
  <span class="character-fallback" aria-hidden="true">✦</span>
</span>

<script>
  const initializeCharacterImages = () => {
    document.querySelectorAll<HTMLElement>('[data-character-image]').forEach((root) => {
      if (root.dataset.ready) return;
      root.dataset.ready = 'true';
      const image = root.querySelector<HTMLImageElement>('img');
      const fallback = () => { root.classList.add('is-fallback'); if (image) image.hidden = true; };
      image?.addEventListener('error', fallback, { once: true });
      if (image?.complete && image.naturalWidth === 0) fallback();
    });
  };
  initializeCharacterImages();
  document.addEventListener('astro:page-load', initializeCharacterImages);
</script>

<style>
  .character-image { display:block; width:100%; height:100%; overflow:hidden; background:#0d0d0c; }
  img { width:100%; height:100%; object-fit:cover; }
  .character-fallback { display:none; width:100%; height:100%; place-items:center; color:var(--gold-dark); font-family:var(--font-display); font-size:2rem; background:radial-gradient(circle, rgba(182,154,99,.08), transparent 60%), #12110f; }
  .character-image.is-fallback .character-fallback { display:grid; }
</style>
