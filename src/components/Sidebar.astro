---
import SearchPanel from './SearchPanel.astro';
import RelationMeter from './RelationMeter.astro';
import Sigil from './Sigil.astro';
import { withBase } from '../lib/paths';
import site from '../data/site.json';
import CharacterImage from './CharacterImage.astro';
import { resolveCharacterImage } from '../lib/characterImages';
interface Character { name: string; slug: string; aliases?: string[]; role: string; image?: string; relationLabel: string; currentRelation: { positive: number; negative: number }; tags: string[] }
interface Diary { title: string; slug: string; excerpt: string; tags: string[] }
interface Quote { text: string; source: string }
interface SearchItem { type: string; title: string; subtitle: string; href: string; keywords: string }
interface Props { characters: Character[]; diaries: Diary[]; quote: Quote; extraSearchItems?: SearchItem[] }
const { characters, diaries, quote, extraSearchItems = [] } = Astro.props;
const searchItems: SearchItem[] = [
  ...characters.map((item) => ({ type: 'Персонаж', title: item.name, subtitle: `${item.role} · ${item.relationLabel}`, href: `/characters/${item.slug}`, keywords: [...(item.aliases??[]),...item.tags].join(' ') })),
  ...diaries.map((item) => ({ type: 'Дневник', title: item.title, subtitle: item.excerpt, href: `/diary/${item.slug}`, keywords: item.tags.join(' ') })),
  ...extraSearchItems,
];
const characterImage = (character: Character) => {
  const image = resolveCharacterImage(character);
  return image ? withBase(image) : undefined;
};
---
<aside class="sidebar" aria-label="Дополнительные материалы">
  <SearchPanel items={searchItems} />

  <section class="side-section character-list">
    <div class="side-heading"><h2>Персонажи</h2><a href={withBase('/characters')}>Все</a></div>
    {characters.slice(0, 5).map((character) => (
      <a class="mini-character" href={withBase(`/characters/${character.slug}`)}>
        <span class="mini-portrait">
          <CharacterImage name={character.name} src={characterImage(character)} />
        </span>
        <span><strong>{character.name}</strong><small>{character.role}</small></span>
        <RelationMeter positive={character.currentRelation.positive} negative={character.currentRelation.negative} compact />
      </a>
    ))}
  </section>

  <section class="side-section quote-card">
    <h2>Цитата дня</h2>
    <blockquote>«{quote.text}»</blockquote>
    <p>— {quote.source}</p>
    <div class="quote-mark"><span></span><Sigil small /><span></span></div>
  </section>

  <section class="side-section thoughts">
    <h2>Последние мысли</h2>
    {site.thoughts.map((thought) => <a href={withBase(thought.href)}><strong>{thought.title}</strong><span>{thought.text}</span></a>)}
  </section>

  <section class="side-section map-card">
    <h2>Карта Баровии</h2>
    <div class="map-preview" aria-hidden="true"><span>✦</span><i></i><b></b></div>
    <a class="map-button" href={withBase('/places')}>Открыть карту <span>→</span></a>
  </section>
</aside>

<style>
  .sidebar { align-self: start; border: 1px solid var(--border); background: rgba(23,21,19,.9); box-shadow: 0 20px 60px rgba(0,0,0,.22); }
  .sidebar > :global(section) + :global(section) { border-top: 1px solid var(--border); }
  .side-section { padding: 1.45rem; }
  .side-section h2 { margin: 0 0 1rem; color: var(--text-bright); font-family: var(--font-display); font-size: 1.45rem; font-weight: 400; }
  .side-heading { display: flex; align-items: baseline; justify-content: space-between; }
  .side-heading a { color: var(--text-muted); font-size: .72rem; text-decoration: none; }
  .mini-character { display: grid; grid-template-columns: 48px 1fr 80px; gap: .7rem; align-items: center; padding: .45rem; margin-top: .55rem; border: 1px solid var(--border); color: var(--text-main); text-decoration: none; background: #151411; transition: border-color .2s, background .2s; }
  .mini-character:hover { border-color: rgba(182,154,99,.55); background: var(--bg-card-hover); }
  .mini-portrait { width: 48px; height: 48px; display: grid; place-items: center; overflow: hidden; background: #0d0d0c; color: var(--gold-dark); }
  .mini-portrait :global(img) { filter: saturate(.65); }
  .mini-character > span:nth-child(2) { min-width: 0; display: grid; }
  .mini-character strong { font-family: var(--font-display); font-weight: 500; font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .mini-character small { color: var(--text-muted); font-size: .68rem; }
  .quote-card blockquote { margin: .5rem .4rem; color: #b9afa2; font-family: var(--font-display); font-size: 1.25rem; line-height: 1.35; font-style: italic; }
  .quote-card > p { margin: .6rem .4rem 0; color: var(--gold-dark); font-size: .72rem; }
  .quote-mark { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: .8rem; margin-top: 1rem; }
  .quote-mark span { height: 1px; background: linear-gradient(90deg, transparent, var(--border)); }
  .quote-mark span:last-child { background: linear-gradient(90deg, var(--border), transparent); }
  .thoughts a { display: grid; gap: .25rem; margin-top: .65rem; padding: .9rem; border: 1px solid rgba(182,154,99,.16); color: var(--text-main); text-decoration: none; background: linear-gradient(135deg, rgba(182,154,99,.06), transparent), #201d19; }
  .thoughts a:hover { border-color: var(--border); }
  .thoughts strong { font-family: var(--font-display); font-weight: 500; }
  .thoughts span { color: var(--text-muted); font-size: .75rem; line-height: 1.45; }
  .map-preview { position: relative; height: 135px; overflow: hidden; border: 1px solid var(--border); background: radial-gradient(circle at 68% 34%, transparent 0 8%, rgba(182,154,99,.09) 9% 10%, transparent 11%), repeating-radial-gradient(ellipse at 50% 50%, transparent 0 18px, rgba(182,154,99,.08) 19px 20px), #141310; }
  .map-preview::before, .map-preview::after { content: ''; position: absolute; inset: 20% -10%; border-top: 1px solid rgba(182,154,99,.15); transform: rotate(-12deg); }
  .map-preview::after { inset: 60% -10%; transform: rotate(7deg); }
  .map-preview span { position: absolute; top: 32%; left: 61%; color: var(--red-light); }
  .map-button { display: flex; justify-content: space-between; margin-top: .55rem; padding: .75rem 1rem; border: 1px solid var(--border); color: var(--text-main); text-decoration: none; font-size: .82rem; background: #241f1a; }
  .map-button:hover { border-color: var(--gold); }
  @media (max-width: 1140px) { .mini-character { grid-template-columns: 48px 1fr; } .mini-character :global(.meters) { display: none; } }
</style>
