---
import { withBase } from '../lib/paths';
interface Props { slug: string; title: string; kind: string; file: string; locationLabel: string; summary: string }
const { slug, title, kind, file, locationLabel, summary } = Astro.props;
const image = withBase(`/images/archives/${file}`);
---
<article class="archive-card document-card reveal-card">
  <a class="document-preview" href={withBase(`/archives/${slug}`)}>
    <img src={image} alt={title} width="900" height="1200" loading="lazy" decoding="async" />
  </a>
  <small>{kind} · {locationLabel}</small>
  <h2><a href={withBase(`/archives/${slug}`)}>{title}</a></h2>
  <p>{summary}</p>
</article>

<style>
  .document-card { display:grid; align-content:start; }
  .document-preview { display:grid; place-items:center; height:260px; margin:-1.3rem -1.3rem 1.1rem; overflow:hidden; border-bottom:1px solid var(--border); background:#0d0d0c; }
  img { width:100%; height:100%; object-fit:cover; object-position:top; filter:saturate(.72) brightness(.8); transition:filter .25s, transform .25s; }
  .document-preview:hover img { filter:saturate(.9) brightness(.95); transform:scale(1.015); }
  h2 { font-size:1.4rem!important; }
  p { margin-bottom:0; }
</style>
