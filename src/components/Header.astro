---
import site from '../data/site.json';
import Sigil from './Sigil.astro';
import { withBase } from '../lib/paths';
const pathname = Astro.url.pathname;
---
<header class="site-header" data-header>
  <div class="header-inner">
    <a class="brand" href={withBase('/')} aria-label="На главную">
      <Sigil small />
      <span>{site.name}</span>
    </a>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="main-navigation">
      <span></span><span></span><span></span><em>Меню</em>
    </button>
    <nav id="main-navigation" aria-label="Основная навигация">
      {site.navigation.map((item) => (
        <a href={withBase(item.href)} aria-current={pathname.includes(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.menu-toggle');
  const nav = document.querySelector<HTMLElement>('#main-navigation');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    nav?.classList.toggle('is-open', !open);
  });
</script>

<style>
  .site-header { position: sticky; top: 0; z-index: 50; border-bottom: 1px solid transparent; background: linear-gradient(180deg, rgba(13,13,12,.97), rgba(13,13,12,.78), transparent); transition: border-color .25s, background .25s; }
  .header-inner { width: min(100% - 3rem, 1440px); min-height: 82px; margin: 0 auto; display: flex; align-items: center; gap: clamp(2rem, 5vw, 5rem); }
  .brand { display: flex; align-items: center; gap: .75rem; color: var(--text-main); text-decoration: none; font-family: var(--font-display); font-size: clamp(1.45rem, 2vw, 1.9rem); white-space: nowrap; }
  nav { display: flex; align-items: center; justify-content: center; gap: clamp(1.2rem, 2.4vw, 2.45rem); flex: 1; }
  nav a { position: relative; color: var(--text-muted); text-decoration: none; font-size: .93rem; letter-spacing: .02em; padding: 1.8rem 0; }
  nav a::after { content: ''; position: absolute; left: 50%; right: 50%; bottom: 1.3rem; height: 1px; background: var(--gold); transition: left .25s, right .25s; }
  nav a:hover, nav a[aria-current='page'] { color: var(--text-main); }
  nav a:hover::after, nav a[aria-current='page']::after { left: 0; right: 0; }
  .menu-toggle { display: none; color: var(--text-main); background: none; border: 0; padding: .75rem; }
  .menu-toggle span { display: block; width: 24px; height: 1px; margin: 5px; background: currentColor; }
  .menu-toggle em { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
  @media (max-width: 1120px) {
    .header-inner { min-height: 68px; justify-content: space-between; }
    .menu-toggle { display: block; }
    nav { display: none; position: absolute; top: 68px; left: 0; right: 0; padding: .5rem 1.5rem 1.5rem; background: rgba(17,16,15,.98); border-bottom: 1px solid var(--border); }
    nav.is-open { display: grid; }
    nav a { padding: .75rem 0; }
    nav a::after { bottom: .4rem; }
  }
  @media (max-width: 560px) { .header-inner { width: min(100% - 1.5rem, 1440px); } }
</style>
