---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../lib/paths';
interface Props { title: string; description?: string; eyebrow?: string }
const { title, description, eyebrow = 'Архив Коэла Ворна' } = Astro.props;
---
<BaseLayout title={`${title} — Коэл Ворн`} description={description}>
  <main id="main-content" class="content-page">
    <header class="page-hero">
      <div class="page-hero__inner">
        <nav aria-label="Хлебные крошки"><a href={withBase('/')}>Коэл Ворн</a><span>✦</span><span>{title}</span></nav>
        <p>{eyebrow}</p>
        <h1>{title}</h1>
        {description && <div class="description">{description}</div>}
      </div>
    </header>
    <div class="content-shell"><slot /></div>
  </main>
</BaseLayout>

<style>
  .content-page { min-height: 70vh; }
  .page-hero { padding: 5.5rem 0 3.5rem; border-bottom: 1px solid var(--border); background: radial-gradient(circle at 75% 20%, rgba(109,38,38,.12), transparent 28%), linear-gradient(180deg, #171513, #11100f); }
  .page-hero__inner, .content-shell { width: min(100% - 3rem, 1180px); margin: 0 auto; }
  nav { display: flex; gap: .65rem; color: var(--text-muted); font-size: .75rem; }
  nav a { color: var(--gold); text-decoration: none; }
  .page-hero__inner > p { margin: 2.2rem 0 .3rem; color: var(--gold); text-transform: uppercase; letter-spacing: .17em; font-size: .7rem; }
  h1 { margin: 0; color: var(--text-bright); font-family: var(--font-display); font-size: clamp(3.8rem, 8vw, 6.5rem); font-weight: 300; line-height: .95; }
  .description { max-width: 720px; margin-top: 1.2rem; color: var(--text-muted); font-size: 1rem; }
  .content-shell { padding: 3.5rem 0 5rem; }
  :global(.archive-grid) { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  :global(.archive-card) { padding: 1.3rem; border: 1px solid var(--border); background: var(--bg-card); }
  :global(.archive-card h2), :global(.archive-card h3) { margin: 0 0 .5rem; color: var(--text-bright); font-family: var(--font-display); font-size: 1.55rem; font-weight: 500; }
  :global(.archive-card a) { color: inherit; text-decoration: none; }
  :global(.archive-card a:hover) { color: var(--gold); }
  :global(.archive-card p) { color: var(--text-muted); font-size: .86rem; }
  :global(.archive-card small), :global(.meta) { color: var(--gold); font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; }
  :global(.prose) { max-width: 780px; color: var(--text-main); font-size: 1.02rem; line-height: 1.8; }
  :global(.prose h2), :global(.prose h3) { color: var(--text-bright); font-family: var(--font-display); font-weight: 500; }
  :global(.detail-grid) { display: grid; grid-template-columns: minmax(0, 2fr) minmax(260px, 1fr); gap: 2.5rem; }
  :global(.side-note) { align-self: start; padding: 1.3rem; border: 1px solid var(--border); background: var(--bg-card); }
  :global(.side-note h2) { margin-top: 0; font-family: var(--font-display); font-weight: 500; }
  :global(.tag-list) { display: flex; flex-wrap: wrap; gap: .45rem; padding: 0; list-style: none; }
  :global(.tag-list li) { padding: .3rem .55rem; border: 1px solid var(--border); color: var(--text-muted); font-size: .73rem; }
  @media (max-width: 800px) { :global(.archive-grid) { grid-template-columns: 1fr 1fr; } :global(.detail-grid) { grid-template-columns: 1fr; } }
  @media (max-width: 540px) { .page-hero__inner, .content-shell { width: min(100% - 1.5rem, 1180px); } :global(.archive-grid) { grid-template-columns: 1fr; } }
</style>
