---
import { getCollection } from 'astro:content';
import ContentLayout from '../layouts/ContentLayout.astro';
import RelationMeter from '../components/RelationMeter.astro';
import { withBase } from '../lib/paths';
import FilterBar from '../components/FilterBar.astro';
import TagList from '../components/TagList.astro';
import relationScale from '../data/relation-scale.json';
const characters = (await getCollection('characters')).map((entry) => entry.data).filter((item) => item.slug !== 'koel').sort((a,b) => b.currentRelation.positive - a.currentRelation.positive);
const options = (values:string[])=>[...new Set(values)].sort((a,b)=>a.localeCompare(b,'ru')).map((value)=>({value,label:value}));
---
<ContentLayout title="Отношения" description="Доверие и враждебность существуют одновременно. Поэтому каждая связь сохраняет две независимые оценки.">
  <FilterBar target="#relationship-list" groups={options(characters.map((item)=>item.group))} tags={options(characters.flatMap((item)=>item.tags))} />
  <label class="sort">Сортировка <select data-relation-sort><option value="positive">По положительному</option><option value="negative">По отрицательному</option><option value="updated">По последнему изменению</option><option value="name">По имени</option></select></label>
  <div class="relationship-list" id="relationship-list">
    {characters.map((character) => <article class="relationship-row" data-filter-item data-search={`${character.name} ${character.role} ${character.relationLabel}`} data-group={character.group} data-tag={character.tags.join('|')} data-positive={character.currentRelation.positive} data-negative={character.currentRelation.negative} data-updated={character.lastUpdatedSession??0} data-name={character.name}><div><small>{character.group}</small><h2><a href={withBase(`/characters/${character.slug}`)}>{character.name}</a></h2><p>{character.relationLabel}</p><TagList tags={character.tags} /></div><RelationMeter positive={character.currentRelation.positive} negative={character.currentRelation.negative} /></article>)}
  </div>
  <details class="scale"><summary>Как читаются значения отношений</summary><div class="scale-grid">{relationScale.map((item)=><article><b class:list={{negative:item.value<0,positive:item.value>0}}>{item.value>0?`+${item.value}`:item.value}</b><div><strong>{item.label}</strong><p>{item.description}</p></div></article>)}</div></details>
</ContentLayout>
<script>const list=document.querySelector<HTMLElement>('#relationship-list');const sort=document.querySelector<HTMLSelectElement>('[data-relation-sort]');sort?.addEventListener('change',()=>{if(!list)return;const rows=[...list.querySelectorAll<HTMLElement>('[data-filter-item]')];rows.sort((a,b)=>sort.value==='name'?(a.dataset.name||'').localeCompare(b.dataset.name||'','ru'):Number(b.dataset[sort.value]||0)-Number(a.dataset[sort.value]||0));rows.forEach((row)=>list.append(row))});</script>
<style>.sort{display:flex;justify-content:flex-end;align-items:center;gap:.6rem;margin:-.5rem 0 1rem;color:var(--text-muted);font-size:.75rem}.sort select{padding:.5rem;border:1px solid var(--border);color:var(--text-main);background:var(--bg-card)}.relationship-list{display:grid;gap:.65rem}.relationship-row[hidden]{display:none}.relationship-row{display:grid;grid-template-columns:1fr minmax(200px,340px);gap:2rem;align-items:center;padding:1.2rem 1.4rem;border:1px solid var(--border);background:var(--bg-card)}small{color:var(--gold);text-transform:uppercase;letter-spacing:.08em}h2{margin:.2rem 0;font-family:var(--font-display);font-weight:500}h2 a{color:var(--text-bright);text-decoration:none}p{margin:0;color:var(--text-muted);font-size:.84rem}.scale{margin-top:2rem;border:1px solid var(--border);background:var(--bg-soft)}.scale summary{padding:1rem 1.2rem;color:var(--gold);cursor:pointer}.scale-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;padding:0 1rem 1rem}.scale-grid article{display:grid;grid-template-columns:2.5rem 1fr;gap:.7rem;padding:.7rem;border:1px solid rgba(182,154,99,.16)}.scale-grid b{font-family:var(--font-display);font-size:1.25rem}.scale-grid b.positive{color:var(--gold)}.scale-grid b.negative{color:#a95b57}.scale-grid strong{font-family:var(--font-display);font-weight:500}.scale-grid p{margin:.15rem 0 0}@media(max-width:700px){.scale-grid{grid-template-columns:1fr}}@media(max-width:600px){.relationship-row{grid-template-columns:1fr;gap:1rem}}</style>
