---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import SectionTitle from '../components/SectionTitle.astro';
import DiaryCard from '../components/DiaryCard.astro';
import RelationCard from '../components/RelationCard.astro';
import PrincipleCard from '../components/PrincipleCard.astro';
import Timeline from '../components/Timeline.astro';
import Sigil from '../components/Sigil.astro';
import site from '../data/site.json';
import { withBase } from '../lib/paths';

const [diaryEntries, characterEntries, principleEntries, chronicleEntries, quoteEntries, placeEntries, libraryEntries] = await Promise.all([
  getCollection('diary'),
  getCollection('characters'),
  getCollection('worldview'),
  getCollection('chronicle'),
  getCollection('quotes'),
  getCollection('places'),
  getCollection('library'),
]);

const diaries = diaryEntries.sort((a, b) => b.data.session - a.data.session).slice(0, 3).map((entry) => entry.data);
const characters = characterEntries.map((entry) => entry.data);
const featuredCharacters = characters.filter((item) => item.featured).sort((a, b) => Math.abs(b.currentRelation.positive) + Math.abs(b.currentRelation.negative) - (Math.abs(a.currentRelation.positive) + Math.abs(a.currentRelation.negative)));
const principles = principleEntries.filter((entry)=>entry.data.category==='Принципы').sort((a, b) => a.data.order - b.data.order).map((entry) => entry.data);
const events = chronicleEntries.sort((a, b) => a.data.session - b.data.session).map((entry) => entry.data);
const quoteIndex = Math.floor(Date.now() / 86_400_000) % quoteEntries.length;
const quote = quoteEntries[quoteIndex].data;
const sidebarCharacters = [...featuredCharacters, ...characters.filter((item)=>!item.featured)].filter((item,index,array)=>array.findIndex((candidate)=>candidate.slug===item.slug)===index);
const extraSearchItems = [
  ...chronicleEntries.map((item)=>({type:'Событие',title:item.data.title,subtitle:item.data.summary,href:`/chronicle#${item.data.slug}`,keywords:item.data.tags.join(' ')})),
  ...placeEntries.map((item)=>({type:'Место',title:item.data.name,subtitle:item.data.region,href:`/places/${item.data.slug}`,keywords:item.data.tags.join(' ')})),
  ...libraryEntries.map((item)=>({type:'Тема',title:item.data.title,subtitle:item.data.summary,href:`/library/${item.data.slug}`,keywords:item.data.tags.join(' ')})),
];
---
<BaseLayout>
  <main id="main-content">
    <section class="hero" style={`--hero-image: url('${withBase('/images/koel-hero.png')}')`}>
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="overline">{site.eyebrow} · Серия {site.currentSession}</p>
          <h1>{site.name}</h1>
          <p class="hero-description">Хранитель врат. Эладрин.<br />Пришёл из-за туманов. Ищет путь обратно.</p>
          <a class="primary-button" href={withBase('/diary')}>Читать дневник <span>→</span></a>
          <div class="hero-quote">
            <span class="quote-glyph" aria-hidden="true">“</span>
            <p>{site.heroQuote}</p>
          </div>
          <div class="ornament" aria-hidden="true"><i></i><Sigil small /><i></i></div>
        </div>
      </div>
    </section>

    <div class="page-grid">
      <div class="main-column">
        <section class="home-section">
          <SectionTitle title="Последние записи" href="/diary" />
          <div class="diary-grid">
            {diaries.map((entry) => <DiaryCard {...entry} />)}
          </div>
        </section>

        <section class="home-section">
          <SectionTitle title="Отношения" href="/relationships" />
          <div class="relations-grid">
            {featuredCharacters.map((character) => (
              <RelationCard name={character.name} slug={character.slug} role={character.role} image={character.image} label={character.relationLabel} positive={character.currentRelation.positive} negative={character.currentRelation.negative} />
            ))}
          </div>
        </section>

        <section class="home-section">
          <SectionTitle title="Мои принципы" href="/worldview" />
          <div class="principles-grid">
            {principles.map((principle) => <PrincipleCard {...principle} />)}
          </div>
        </section>

        <section class="home-section chronicle-section">
          <SectionTitle title="Хроника" href="/chronicle" />
          <Timeline events={events} />
        </section>
      </div>

      <Sidebar characters={sidebarCharacters} diaries={diaryEntries.map((entry)=>entry.data)} {quote} {extraSearchItems} />
    </div>
  </main>
</BaseLayout>

<style>
  .hero { position: relative; min-height: 720px; margin-top: -82px; padding-top: 82px; display: grid; align-items: center; background-image: linear-gradient(90deg, rgba(12,12,11,.97) 2%, rgba(12,12,11,.87) 28%, rgba(12,12,11,.25) 58%, rgba(12,12,11,.12)), linear-gradient(0deg, var(--bg-main) 0%, transparent 30%), var(--hero-image); background-position: center; background-size: cover; border-bottom: 1px solid var(--border); }
  .hero::after { content: ''; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(circle at 78% 38%, transparent 0 20%, rgba(0,0,0,.23) 62%, rgba(0,0,0,.58) 100%); }
  .hero-inner { position: relative; z-index: 1; width: min(100% - 3rem, 1440px); margin: 0 auto; }
  .hero-copy { width: min(590px, 47%); padding: 5rem 0 3rem 4rem; }
  .overline { color: var(--gold); font-size: .72rem; text-transform: uppercase; letter-spacing: .2em; }
  h1 { margin: .35rem 0 .5rem; color: #ded7cd; font-family: var(--font-display); font-size: clamp(5.2rem, 8vw, 8rem); font-weight: 300; line-height: .92; letter-spacing: -.045em; text-shadow: 0 3px 28px #000; }
  .hero-description { color: var(--text-main); font-family: var(--font-display); font-size: 1.18rem; line-height: 1.45; }
  .primary-button { display: inline-flex; align-items: center; justify-content: space-between; gap: 2.6rem; margin-top: 1.3rem; padding: .9rem 1.15rem; border: 1px solid var(--border); color: var(--text-main); background: rgba(28,25,22,.7); text-decoration: none; text-transform: uppercase; font-size: .72rem; letter-spacing: .09em; transition: border-color .25s, background .25s; }
  .primary-button:hover { border-color: var(--gold); background: rgba(53,22,22,.72); }
  .primary-button span { color: var(--gold); font-size: 1rem; }
  .hero-quote { position: relative; display: grid; grid-template-columns: 2rem 1fr; margin-top: 3rem; max-width: 390px; color: var(--text-muted); font-family: var(--font-display); font-style: italic; }
  .hero-quote p { margin: .4rem 0; line-height: 1.5; }
  .quote-glyph { color: var(--gold-dark); font-size: 3rem; line-height: 1; }
  .ornament { width: 320px; display: grid; grid-template-columns: 1fr auto 1fr; gap: .7rem; align-items: center; margin-top: 1.2rem; }
  .ornament i { height: 1px; background: linear-gradient(90deg, transparent, var(--border)); }
  .ornament i:last-child { background: linear-gradient(90deg, var(--border), transparent); }
  .page-grid { width: min(100% - 3rem, 1440px); margin: 0 auto; display: grid; grid-template-columns: minmax(0, 3fr) minmax(290px, 1fr); gap: 2.2rem; align-items: start; }
  .main-column { min-width: 0; }
  .home-section { margin-top: 4.25rem; }
  .diary-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 1rem; }
  .relations-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: .65rem; margin-top: 1rem; }
  .principles-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: .65rem; margin-top: 1rem; }
  .chronicle-section { margin-bottom: 5rem; }
  .chronicle-section :global(.timeline) { margin-top: 1rem; }
  .page-grid > :global(.sidebar) { position: sticky; top: 96px; margin-top: -12rem; z-index: 4; }
  @media (max-width: 1140px) {
    .hero-copy { padding-left: 1rem; }
    .page-grid { grid-template-columns: minmax(0, 2.5fr) minmax(255px, 1fr); gap: 1.2rem; }
    .diary-grid { grid-template-columns: repeat(2, 1fr); }
    .diary-grid > :last-child { display: none; }
    .relations-grid, .principles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 860px) {
    .hero { min-height: 650px; background-position: 62% center; }
    .hero-copy { width: min(500px, 68%); padding-left: 0; }
    .page-grid { grid-template-columns: 1fr; }
    .page-grid > :global(.sidebar) { position: static; margin-top: 1rem; }
  }
  @media (max-width: 600px) {
    .hero { min-height: 640px; margin-top: -68px; padding-top: 68px; align-items: end; background-position: 66% center; background-image: linear-gradient(90deg, rgba(12,12,11,.9), rgba(12,12,11,.22)), linear-gradient(0deg, var(--bg-main) 3%, rgba(12,12,11,.92) 26%, transparent 60%), var(--hero-image); }
    .hero-inner, .page-grid { width: min(100% - 1.5rem, 1440px); }
    .hero-copy { width: 100%; padding: 3rem 0; }
    h1 { font-size: clamp(4.3rem, 21vw, 6rem); }
    .hero-quote, .ornament { display: none; }
    .home-section { margin-top: 3rem; }
    .diary-grid { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: .5rem; }
    .diary-grid > :global(*) { min-width: min(82vw, 330px); scroll-snap-align: start; }
    .diary-grid > :last-child { display: block; }
    .relations-grid { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: .5rem; }
    .relations-grid > :global(*) { min-width: min(68vw, 270px); scroll-snap-align: start; }
    .principles-grid { grid-template-columns: 1fr; }
  }
</style>
