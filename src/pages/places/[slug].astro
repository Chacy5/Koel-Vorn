---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { withBase } from '../../lib/paths';
import TagList from '../../components/TagList.astro';
export async function getStaticPaths(){return (await getCollection('places')).map((entry)=>({params:{slug:entry.data.slug},props:{entry}}))}
const {entry}=Astro.props; const {Content}=await render(entry);
const [diaries,events,characters]=await Promise.all([getCollection('diary'),getCollection('chronicle'),getCollection('characters')]);
const relatedDiaries=diaries.filter((item)=>item.data.places.includes(entry.data.slug));
const relatedEvents=events.filter((item)=>item.data.places.includes(entry.data.slug));
const characterSlugs=[...new Set([...relatedDiaries.flatMap((item)=>item.data.characters),...relatedEvents.flatMap((item)=>item.data.characters)])];
const relatedCharacters=characterSlugs.map((slug)=>characters.find((item)=>item.data.slug===slug)?.data).filter(Boolean);
---
<ContentLayout title={entry.data.name} eyebrow={entry.data.region} description={`Место в хронике Коэла Ворна: ${entry.data.name}.`}><div class="detail-grid"><article class="prose">{entry.data.image&&<img src={withBase(entry.data.image)} alt="" />}<Content />{relatedEvents.length>0&&<><h2>События</h2><div class="links">{relatedEvents.map((item)=><a href={withBase(`/chronicle#${item.data.slug}`)}><small>Серия {item.data.session}</small>{item.data.title}</a>)}</div></>}{relatedDiaries.length>0&&<><h2>Дневники</h2><div class="links">{relatedDiaries.map((item)=><a href={withBase(`/diary/${item.data.slug}`)}><small>Серия {item.data.session}</small>{item.data.title}</a>)}</div></>}</article><aside class="side-note"><h2>Связано с</h2><TagList tags={entry.data.tags} />{relatedCharacters.length>0&&<><h3>Персонажи</h3><ul>{relatedCharacters.map((item:any)=><li><a href={withBase(`/characters/${item.slug}`)}>{item.name}</a></li>)}</ul></>}</aside></div></ContentLayout>
<style>img{width:100%;max-height:460px;object-fit:cover;margin-bottom:2rem;filter:saturate(.72) brightness(.82)}.links{display:grid;gap:.5rem}.links a{display:grid;padding:.75rem;border:1px solid var(--border);color:var(--text-main);text-decoration:none}.links a:hover{border-color:var(--gold)}.links small{color:var(--gold)}aside a{color:var(--text-main);text-decoration:none}aside a:hover{color:var(--gold)}</style>
